# ==============================
# Join Domain Script (Windows Server 2016)
# ==============================

# Variables
$DomainName = "yourdomain.local"
$OUPath = "OU=Servers,DC=yourdomain,DC=local"   # Optional, set to $null if not needed
$RestartAfterJoin = $true

# Prompt for domain credentials
$Credential = Get-Credential -Message "Enter domain admin credentials"

try {
    Write-Host "Joining domain $DomainName..." -ForegroundColor Cyan

    if ($OUPath -ne $null -and $OUPath -ne "") {
        Add-Computer `
            -DomainName $DomainName `
            -OUPath $OUPath `
            -Credential $Credential `
            -ErrorAction Stop
    } else {
        Add-Computer `
            -DomainName $DomainName `
            -Credential $Credential `
            -ErrorAction Stop
    }

    Write-Host "Successfully joined domain." -ForegroundColor Green

    if ($RestartAfterJoin) {
        Write-Host "Restarting system..." -ForegroundColor Yellow
        Restart-Computer -Force
    }

} catch {
    Write-Host "Failed to join domain:" -ForegroundColor Red
    Write-Host $_.Exception.Message
}
